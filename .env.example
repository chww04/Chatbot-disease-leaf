# ── Existing keys ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
APP_API_KEY=your_secret_app_api_key_here

# ── CV Model (Cloud Run) ───────────────────────────────────────
# Set this after running deploy.sh
CV_SERVICE_URL=https://cv-disease-service-xxxx-uc.a.run.app

# ── CV Model (Vertex AI Endpoint) ─────────────────────────────
# Set this after deploy.sh creates the endpoint
# If set, Vertex AI takes priority over CV_SERVICE_URL
VERTEX_ENDPOINT_ID=1234567890123456789
VERTEX_REGION=us-central1
GOOGLE_CLOUD_PROJECT=melvin-ai-490502

# ── GCS (for cv_service.py to download model) ─────────────────
GCS_BUCKET=leaf_disease1
MODEL_GCS_PATH=models/rice_disease_model.keras
